run = ["bash", "-lc", "npm i --silent && PORT=3001 npm run oneport"]
entrypoint = "server/src/index.ts"

[nix]
channel = "stable-24_11"

[[ports]]
localPort = 3001
externalPort = 80

[workflows]
runButton = "Run"

[[workflows.workflow]]
name = "Run"
author = 22514457
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=3001 npm run oneport"
